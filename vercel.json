{
    "version": 2,
    "functions": {
        "api/**/*.ts": {
            "includeFiles": "{prisma/**,node_modules/.prisma/**,**/*.node}"
        },
        "api/**/*.js": {
            "includeFiles": "{prisma/**,node_modules/.prisma/**,**/*.node}"
        }
    },
    "rewrites": [
        { "source": "/api/:path*", "destination": "/api/index.ts" },
        { "source": "/admin/:path*", "destination": "/admin/index.html" },
        { "source": "/((?!api/|admin/|static/|favicon\\.ico).*)", "destination": "/index.html" }
    ]
}